{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crisma-presenca",
  "main": "src/index.js",
  "compatibility_date": "2025-06-01",
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      { "name": "PRESENCE", "class_name": "PresenceRoom" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["PresenceRoom"] }
  ]
}
